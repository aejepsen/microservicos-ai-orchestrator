# Copie para .env e troque as chaves. Nunca commite o .env.
INTERNAL_KEY=troque-por-chave-forte-openssl-rand-hex-32
QDRANT_API_KEY=troque-por-chave-qdrant

# Modelo de referência (decisão em SDD/NEXT_PHASES.md §9.4): fine-tune do
# AI-Orchestrator, 5.8 GB quantizado, 100% na GPU de 12 GB (RTX 3060).
# Já presente no volume compartilhado; senão: make model
MODEL=qwen3.5-9b-orch

LOG_LEVEL=INFO

# Grafana (FASE 12): admin / senha abaixo — http://127.0.0.1:3000
GRAFANA_PASSWORD=troque-por-senha-forte
