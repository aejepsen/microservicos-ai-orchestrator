{
 "uid": "msvc-deps",
 "title": "MSVC \u2014 Dependency Health",
 "schemaVersion": 39,
 "version": 1,
 "time": {
  "from": "now-1h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Stale por servi\u00e7o",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 12,
    "h": 8
   },
   "targets": [
    {
     "expr": "count by (service) (latency_ms_p95{stale=\"true\"})",
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "{{service}}"
    }
   ]
  },
  {
   "title": "TTFT inference (ms)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "gridPos": {
    "x": 12,
    "y": 0,
    "w": 12,
    "h": 8
   },
   "targets": [
    {
     "expr": "ttft_ms_p50",
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "p50"
    },
    {
     "expr": "ttft_ms_p95",
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "p95"
    }
   ]
  },
  {
   "title": "HITL pausados (orchestrator)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "targets": [
    {
     "expr": "paused_total",
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "{{service}}"
    }
   ]
  },
  {
   "title": "Ingests/chunks RAG",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prom"
   },
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "targets": [
    {
     "expr": "ingests_total",
     "refId": "A",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "ingests"
    },
    {
     "expr": "chunks_total",
     "refId": "B",
     "datasource": {
      "type": "prometheus",
      "uid": "prom"
     },
     "legendFormat": "chunks"
    }
   ]
  }
 ]
}