    {"id": "svc_evals_api_openapi_targetspec", "label": "TargetSpec schema (live mode target)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_api_openapi_run", "label": "POST /v1/run endpoint", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_golden_set", "label": "Golden Set (JSONL labeled cases)", "file_type": "concept", "rationale": "Golden is immutable during runs and never adjustable to pass a gate (template rule 12.7): a case the engine gets wrong is an engine bug, not a golden bug.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_scorer", "label": "Pluggable Scorer", "file_type": "concept", "rationale": "Pure function (case, obtained_response) -> {passed, score}; metrics implemented in pure stdlib Python (no numpy/sklearn) to keep pyproject lean since svc-evals loads no model and does no heavy algebra.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_gate", "label": "Numeric Gate (metric, comparator, threshold -> PASS/FAIL)", "file_type": "concept", "rationale": "In the AIO baseline each feature declares a numeric gate (Recall@3 >= 80%, routing >= 90%, faithfulness >= 90%) and the number decides production entry; edge cases (value == threshold per comparator) are explicitly tested in G2.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_source_label", "label": "Metric Source Label (live/eval/estimate)", "file_type": "concept", "rationale": "Every persisted metric is labeled with its origin: live = real traces/counters, eval = golden set with date, estimate = formula. Pattern extracted from AIO EvalResultsCollector (eval_results.py).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_llm_judge_adapter", "label": "LLM Judge Adapter (HTTP OpenAI-compatible, off by default)", "file_type": "concept", "rationale": "svc-evals is build round 2, before svc-inference (round 3); to avoid an out-of-order dependency the judge is a generic OpenAI-compatible HTTP adapter (HttpJudge) enabled only with JUDGE_ENABLED=1. Determinism: temperature=0, response_format=json_object, parse tolerant to junk around JSON. Dogfood uses a deterministic FakeJudge so gates run with zero network.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_spec_trap_case", "label": "Trap Case (armadilha) in golden sets", "file_type": "concept", "rationale": "Institutionalized pilot lesson: goldens carry traps — cases that look like the opposite of their label — to prevent false positives/negatives; every dogfood golden must include at least one trap.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_decisions_jsonpath_safe_subset", "label": "Safe JSONPath subset (own navigator, no eval)", "file_type": "rationale", "rationale": "Golden and response are untrusted data; the output_pointer navigator (jsonpath.py) only resolves dict keys and list indices — never eval/exec — so a malicious golden can never be interpreted as code.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_decisions_anti_ssrf", "label": "Anti-SSRF validation of target/judge URLs", "file_type": "rationale", "rationale": "target/judge URLs allow only http/https and host resolution blocks private networks, cloud metadata (169.254.0.0/16) and loopback unless ALLOW_LOCAL_TARGET=1 — prevents a malicious golden from making the service hit internal endpoints.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_decisions_resultsstore_filter", "label": "ResultsStore ignores non-payload artifacts", "file_type": "rationale", "rationale": "Dogfood bug: eval scripts wrote their own artifacts (engine_*.json) into evals/results/, the same folder ResultsStore reads, breaking GET /v1/results with KeyError 'suite'. Fixed at two levels: ResultsStore only considers files with all run-payload keys, and the bench uses an isolated temporary results_dir. Robustness also holds in production (strange files in the folder cannot take the endpoint down).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_evals_compose_evals", "label": "svc-evals compose service (port 8201)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/compose.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_readme_svc_guardrails", "label": "svc-guardrails Service (text security analysis)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_api_openapi_analyzerequest", "label": "AnalyzeRequest schema", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_api_openapi_analyzeresponse", "label": "AnalyzeResponse schema", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_api_openapi_oodfitrequest", "label": "OodFitRequest schema", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_sanitization", "label": "Input Sanitization (chat delimiter neutralization)", "file_type": "concept", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_injection_detection", "label": "Prompt Injection Detection (deterministic PT-BR lexicon)", "file_type": "concept", "rationale": "Detection runs over the ORIGINAL pre-sanitization text: a received <|im_start|> is attack evidence even if sanitization removes it — sanitization protects the downstream, detection preserves the signal (DECISIONS D4). Lexicon: >=12 rule families in patterns_pt.py; rules require imperative context + instruction object, not bare words, to keep FPR <= 5%.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_ood_guard", "label": "OOD Guard (SVD subspace residual)", "file_type": "concept", "rationale": "AIO lesson institutionalized: subspace fit must exclude clarification cases (out-of-domain by design, they contaminate the subspace); artifact (ood_subspace.npz + ood_meta.json) lives in a volume outside git; absence degrades to null verdict, not error.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_loo_calibration", "label": "LOO Threshold Calibration (Youden point)", "file_type": "concept", "rationale": "SPEC requires threshold via leave-one-out (80/20 split overestimated the threshold in AIO; hardcoding AIO's 0.48 is forbidden — different corpus). Implemented as Youden point (max TPR-FPR) over LOO residuals; pilot corpus gave AUC_LOO 0.9992, threshold ~0.817 derived from the corpus itself.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_decisions_auc_mann_whitney", "label": "AUC via Mann-Whitney U (no sklearn)", "file_type": "rationale", "rationale": "AUC computed via Mann-Whitney U statistic (ranks) to avoid a scikit-learn dependency and keep pyproject lean (numpy already present for the SVD subspace).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_decision_policy", "label": "Decision Policy (allow/flag/block)", "file_type": "concept", "rationale": "Deterministic and configurable: injection.flagged -> block always (non-negotiable); ood.flagged -> OOD_ACTION (flag default, mirroring AIO log-only mode; block opt-in); no flag -> allow.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_spec_fail_closed_auth", "label": "Fail-closed Internal Auth (X-Internal-Key + hmac.compare_digest)", "file_type": "concept", "rationale": "Without a configured credential, protected endpoints answer 401 — never open. Cross-cutting NFR from ARCHITECTURE 3.1 applied by every service in the ecosystem; ALLOW_OPEN_ACCESS=1 is a dev-only escape hatch that logs a warning at boot.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_guardrails_compose_guardrails", "label": "svc-guardrails compose service (port 8200)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-guardrails/compose.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_readme_svc_inference", "label": "svc-inference Service (OpenAI-compatible LLM facade)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_api_openapi_chatcompletionrequest", "label": "ChatCompletionRequest schema", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_api_openapi_chatcompletionresponse", "label": "ChatCompletionResponse schema", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_api_openapi_usage", "label": "Usage schema (prompt/completion/total tokens)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_openai_facade", "label": "OpenAI-compatible Inference Facade (Backend Protocol)", "file_type": "concept", "rationale": "OpenAI subset is the de-facto contract; the vendor (Ollama) sits behind a Backend Protocol so consumers (svc-router, svc-orchestrator, svc-evals as judge) never couple to Ollama — swapping to vLLM/TGI is a new adapter without breaking the contract (DECISIONS D1).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_circuit_breaker", "label": "Circuit Breaker (3 transport failures -> OPEN 30s -> half-open)", "file_type": "concept", "rationale": "Only transport failures (BackendError) count; a backend 4xx is BackendBusiness and returns 503 without incrementing the circuit counter — business error is not unavailability (DECISIONS D4, explicit trap case in G4: 5 4xx calls leave the circuit CLOSED). Circuit OPEN -> immediate 503 without hitting the backend. CircuitState uses StrEnum (py3.12 idiom, ruff UP042).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_fakebackend", "label": "FakeBackend (deterministic backend for offline gates)", "file_type": "concept", "rationale": "Spec rule 12.8: no gate may require Ollama running. FakeBackend returns predictable content and usage (completion_tokens = len(reply.split())) and is configurable to fail (transport vs 4xx); real Ollama is exercised only in the optional make smoke.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_usage_at_source", "label": "Token Usage at Source (never estimated)", "file_type": "concept", "rationale": "The facade reads prompt_tokens/completion_tokens from what the backend reports (Ollama: prompt_eval_count/eval_count); if the backend does not report, usage reflects what came (explicit 0, not invented). Reproduces the AIO lesson: the tokens=0 root cause was instrumentation outside the trace (DECISIONS D3); G3 proves propagation to /metrics.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_ttft", "label": "TTFT (time-to-first-token) measurement", "file_type": "concept", "rationale": "The latency the user actually feels in streaming; measured and reported (p50/p95 in /metrics) but not gated because it depends on hardware/model.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_spec_otel_genai", "label": "OTel GenAI Semantic Conventions (gen_ai.* spans/histograms)", "file_type": "concept", "rationale": "Span per call with gen_ai.request.model, gen_ai.usage.input/output_tokens, gen_ai.response.finish_reasons; histograms token.usage, operation.duration, server.time_to_first_token. Opt-in via OTEL_ENABLED=1, no-op otherwise (graceful degradation of telemetry). Pattern extracted from AIO gateway/otel.py.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_inference_compose_inference", "label": "svc-inference compose service (port 8202)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-inference/compose.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_readme_svc_observability", "label": "svc-observability Service (ecosystem metrics aggregator)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_api_openapi_metric", "label": "Metric schema (name, value, source, service, stale)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_api_openapi_evalresultin", "label": "EvalResultIn schema (eval ingestion payload)", "file_type": "code", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/api/openapi.yaml", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_spec_source_rule", "label": "Non-negotiable Source Rule (scraped=live, ingested=eval, computed=estimate)", "file_type": "concept", "rationale": "Derived metrics (e.g. ecosystem_tokens_total) are ESTIMATE by construction in the aggregator and can never become live; a projection labeled live is the explicit trap in gate G3. Reproduces the AIO dashboard fix where faithfulness had to read the real eval result, not a fixed value (DECISIONS D3). It is an aggregator that SCRAPES /metrics (pull), NOT an OTLP Collector (that is infra).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_spec_fakescraper", "label": "FakeScraper (deterministic upstream scraper for offline gates)", "file_type": "concept", "rationale": "HttpScraper (prod, scrapes /metrics with UPSTREAM_KEY) + deterministic FakeScraper (gates, offline) — the adapter+fake pattern from template 8.5; no gate requires an upstream running (DECISIONS D2).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_spec_stale_cache", "label": "Stale-cache Degradation (upstream down keeps old metrics with stale=true)", "file_type": "concept", "rationale": "Upstream down during scrape: service marked ok=false, old metrics kept flagged stale=true — stale cache is better than zero observability (AIO MetricsCollector pattern, DECISIONS D4); overview never crashes on a dead upstream.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_spec_prometheus_exposition", "label": "Hand-generated Prometheus Text Exposition", "file_type": "concept", "rationale": "Exposition generated by hand (# HELP / # TYPE / name{labels} value) because the format is simple enough — avoids a heavy Prometheus client dependency; names sanitized, labels escaped, and G4 reparses the generated text to validate it (DECISIONS D5). Reproduces the AIO fan-out to Prometheus :8889.", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
    {"id": "svc_observability_decisions_anti_ssrf_upstream", "label": "Anti-SSRF validation of upstream URLs at boot", "file_type": "rationale", "rationale": "Upstream URLs (operator config) validated at boot: only http/https, metadata/loopback blocked unless ALLOW_LOCAL_UPSTREAM=1 (dev upstreams are service names/localhost); the allow test uses a literal public IP per template 8.5 (DECISIONS D6).", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-observability/DECISIONS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
