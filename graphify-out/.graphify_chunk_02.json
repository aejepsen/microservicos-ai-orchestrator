    {"id": "svc_evals_readme_svc_evals", "label": "svc-evals Service (golden-set eval engine)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-evals/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null},
