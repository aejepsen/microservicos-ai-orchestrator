    {"id": "svc_orchestrator_readme_svc_orchestrator", "label": "svc-orchestrator (serviço de orquestração multi-agente)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-orchestrator/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extraído do grafo validado em produção do AI-Orchestrator (graph.py, write_intent.py) sem LangGraph — pipeline linear + fan-out em Python puro; é o teste de integração do ecossistema inteiro, construído por último de propósito."},
