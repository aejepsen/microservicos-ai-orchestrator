    {"id": "svc_rag_readme_svc_rag", "label": "svc-rag (recuperação fundamentada: ingestão, busca semântica, GraphRAG)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-rag/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extraído de document_search.py + ingest_documents.py + community_summaries.py do AI-Orchestrator; Recall@3 medido 1.000 (12/12) contra baseline AIO 100%."},
    {"id": "svc_rag_api_openapi_ingest", "label": "POST /v1/ingest (chunk + embed + store, idempotente)", "file_type": "document", "source_file": "/home/aejepsen/Documentos/projeto-portifolio/microservicos-ai-orchestrator/svc-rag/api/openapi.yaml", "source_location": "paths./v1/ingest", "source_url": null, "captured_at": null, "author": null, "contributor": null},
